#!/usr/bin/env bash
# growth-machine CLI launcher: locates the project root and runs the
# TypeScript source directly via the local tsx binary — no global install,
# no precompiled build artifact required.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec "$DIR/node_modules/.bin/tsx" "$DIR/src/cli.ts" "$@"
